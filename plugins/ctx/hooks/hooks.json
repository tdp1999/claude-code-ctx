{
  "description": "CTX execution logging hooks",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'mkdir -p \"${CLAUDE_PLUGIN_DATA}/ctx-logs\" && echo \"[$(date -u +%Y-%m-%dT%H:%M:%SZ)] PostToolUse: Skill invoked\" >> \"${CLAUDE_PLUGIN_DATA}/ctx-logs/hook-debug.log\"'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
